// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum BranchCode {
  SBY
  YOG
}

enum CylinderSize {
  KG12
  KG50
}

enum PoStatus {
  DRAFT
  SUBMITTED
  CONFIRMED
  PARTIALLY_RECEIVED
  COMPLETED
  CANCELLED
}

enum DoStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
  PARTIAL
  CANCELLED
}

enum CustomerType {
  RETAIL
  AGEN
  INDUSTRI
}

enum WriteoffReason {
  RUSAK_BERAT
  HILANG
  KADALUARSA_UJI
  BOCOR_PARAH
}

enum ReconciliationStatus {
  OPEN
  LOCKED
}

enum GasbackTxType {
  CREDIT
  DEBIT
  ADJUSTMENT
}

enum UserRole {
  SUPER_ADMIN
  BRANCH_MANAGER
  WAREHOUSE_STAFF
  SALES_STAFF
  FINANCE
  READONLY
}

enum OrderChannel {
  WHATSAPP
  PHONE
  WALK_IN
  SALES_VISIT
}

enum ReturnSource {
  CUSTOMER
  DRIVER
  DEPOT
}

enum CylinderStatus {
  WAREHOUSE_FULL
  WAREHOUSE_EMPTY
  IN_TRANSIT
  WITH_CUSTOMER
  RETURNED_TO_SUPPLIER
  WRITTEN_OFF
}

enum EmployeeRoleType {
  DRIVER
  KENEK
  WAREHOUSE
  ADMIN
  FINANCE
  SALES
  BRANCH_MANAGER
  MECHANIC
  OTHER
}

// NEW: custody event types for individual cylinder tracking
enum CylinderEventType {
  RECEIVED_FROM_SUPPLIER   // GR inbound — cylinder arrives at warehouse full
  DISPATCHED_TO_CUSTOMER   // DO dispatched — cylinder leaves warehouse
  RETURNED_FROM_CUSTOMER   // Empty return — cylinder comes back, weighed here
  TRANSFERRED_BETWEEN_BRANCH
  WRITTEN_OFF
  INSPECTION               // Periodic inspection / test
}

// NEW: condition flags
enum CylinderCondition {
  GOOD
  DAMAGED
  NEEDS_INSPECTION
  CONDEMNED
}

// ─── Tables ───────────────────────────────────────────────────────────────────

model Branch {
  id        String     @id @default(cuid())
  code      BranchCode @unique
  name      String     @db.VarChar(120)
  address   String?    @db.Text
  phone     String?    @db.VarChar(30)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  suppliers         SupplierHmtQuota[]
  customers         Customer[]
  employees         Employee[]
  supplierPos       SupplierPo[]
  inboundReceivings InboundReceiving[]
  customerPos       CustomerPo[]
  deliveryOrders    DeliveryOrder[]
  emptyReturns      EmptyReturn[]
  cylinderWriteoffs CylinderWriteoff[]
  warehouseStocks   WarehouseStock[]
  cylinderHoldings  CustomerCylinderHolding[]
  gasbackLedgers    GasbackLedger[]
  gasbackClaims     GasbackClaim[]
  monthlyRecons     MonthlyRecon[]
  users             User[]
  // NEW: individual cylinder units registered to this branch
  cylinderUnits     CylinderUnit[]
  cylinderEvents    CylinderEvent[]
}

model Supplier {
  id        String   @id @default(cuid())
  code      String   @unique @db.VarChar(20)
  name      String   @db.VarChar(200)
  npwp      String?  @db.VarChar(30)
  address   String?  @db.Text
  phone     String?  @db.VarChar(30)
  email     String?  @db.VarChar(120)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hmtQuotas SupplierHmtQuota[]
  pos       SupplierPo[]
}

model SupplierHmtQuota {
  id           String       @id @default(cuid())
  supplierId   String
  branchId     String
  cylinderSize CylinderSize
  periodMonth  Int
  periodYear   Int
  quotaQty     Int
  usedQty      Int          @default(0)
  pricePerUnit Decimal      @db.Decimal(14, 2)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id])
  branch   Branch   @relation(fields: [branchId], references: [id])

  @@unique([supplierId, branchId, cylinderSize, periodMonth, periodYear])
}

model Customer {
  id              String       @id @default(cuid())
  branchId        String
  code            String       @unique @db.VarChar(30)
  name            String       @db.VarChar(200)
  customerType    CustomerType
  phone           String?      @db.VarChar(30)
  email           String?      @db.VarChar(120)
  address         String?      @db.Text
  npwp            String?      @db.VarChar(30)
  creditLimitKg12 Int          @default(0)
  creditLimitKg50 Int          @default(0)
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  branch           Branch                    @relation(fields: [branchId], references: [id])
  customerPos      CustomerPo[]
  emptyReturns     EmptyReturn[]
  cylinderHoldings CustomerCylinderHolding[]
  gasbackLedgers   GasbackLedger[]
  gasbackClaims    GasbackClaim[]
  // NEW: individual cylinder events (custody history)
  cylinderEvents   CylinderEvent[]
}

model Employee {
  id           String    @id @default(cuid())
  branchId     String
  userId       String?   @unique
  employeeCode String    @unique @db.VarChar(20)
  fullName     String    @db.VarChar(120)
  displayName  String    @db.VarChar(60)
  isActive     Boolean   @default(true)
  joinDate     DateTime?
  notes        String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  branch        Branch          @relation(fields: [branchId], references: [id])
  user          User?           @relation(fields: [userId], references: [id])
  roles         EmployeeRole[]
  drivenOrders  DeliveryOrder[] @relation("Driver")
  kenetOrders   DeliveryOrder[] @relation("Kenek")
  drivenReturns EmptyReturn[]
}

model EmployeeRole {
  id         String           @id @default(cuid())
  employeeId String
  role       EmployeeRoleType
  assignedAt DateTime         @default(now())
  notes      String?          @db.Text

  employee Employee @relation(fields: [employeeId], references: [id])
}

model SupplierPo {
  id          String    @id @default(cuid())
  branchId    String
  supplierId  String
  poNumber    String    @unique @db.VarChar(50)
  status      PoStatus  @default(DRAFT)
  kg12Qty     Int       @default(0)
  kg50Qty     Int       @default(0)
  confirmedAt DateTime?
  notes       String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  branch    Branch             @relation(fields: [branchId], references: [id])
  supplier  Supplier           @relation(fields: [supplierId], references: [id])
  inbounds  InboundReceiving[]
}

model InboundReceiving {
  id           String    @id @default(cuid())
  branchId     String
  supplierPoId String?
  grNumber     String    @unique @db.VarChar(50)
  receivedAt   DateTime
  kg12Received Int       @default(0)
  kg12Good     Int       @default(0)
  kg12Reject   Int       @default(0)
  kg50Received Int       @default(0)
  kg50Good     Int       @default(0)
  kg50Reject   Int       @default(0)
  notes        String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  branch     Branch      @relation(fields: [branchId], references: [id])
  supplierPo SupplierPo? @relation(fields: [supplierPoId], references: [id])
}

model CustomerPo {
  id         String        @id @default(cuid())
  branchId   String
  customerId String
  poNumber   String        @unique @db.VarChar(50)
  status     PoStatus      @default(DRAFT)
  channel    OrderChannel?
  kg12Qty    Int           @default(0)
  kg50Qty    Int           @default(0)
  notes      String?       @db.Text
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  branch         Branch          @relation(fields: [branchId], references: [id])
  customer       Customer        @relation(fields: [customerId], references: [id])
  deliveryOrders DeliveryOrder[]
}

model DeliveryOrder {
  id            String    @id @default(cuid())
  branchId      String
  customerPoId  String
  doNumber      String    @unique @db.VarChar(30)
  doDate        DateTime  @db.Date
  supplierPoRef String?   @db.VarChar(50)
  driverId      String?
  kenetId       String?
  driverName    String?   @db.VarChar(120)
  vehicleNo     String?   @db.VarChar(20)
  status        DoStatus  @default(PENDING)
  kg12Released  Int       @default(0)
  kg12Delivered Int       @default(0)
  kg50Released  Int       @default(0)
  kg50Delivered Int       @default(0)
  deliveredAt   DateTime?
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  branch         Branch          @relation(fields: [branchId], references: [id])
  customerPo     CustomerPo      @relation(fields: [customerPoId], references: [id])
  driver         Employee?       @relation("Driver", fields: [driverId], references: [id])
  kenek          Employee?       @relation("Kenek", fields: [kenetId], references: [id])
  gasbackLedgers GasbackLedger[]
  // NEW: link to individual cylinder dispatch events
  cylinderEvents CylinderEvent[]
}

model EmptyReturn {
  id           String       @id @default(cuid())
  branchId     String
  returnNumber String       @unique @db.VarChar(50)
  source       ReturnSource
  customerId   String?
  driverId     String?
  kg12Qty      Int          @default(0)
  kg50Qty      Int          @default(0)
  returnedAt   DateTime
  notes        String?      @db.Text
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  branch   Branch    @relation(fields: [branchId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  driver   Employee? @relation(fields: [driverId], references: [id])
  // NEW: link to individual cylinder return/weigh events
  cylinderEvents CylinderEvent[]
}

model CylinderWriteoff {
  id             String         @id @default(cuid())
  branchId       String
  writeoffNumber String         @unique @db.VarChar(50)
  reason         WriteoffReason
  kg12Qty        Int            @default(0)
  kg50Qty        Int            @default(0)
  writeoffAt     DateTime
  notes          String?        @db.Text
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  branch         Branch          @relation(fields: [branchId], references: [id])
  // NEW: individual cylinder write-off events
  cylinderEvents CylinderEvent[]
}

model WarehouseStock {
  id               String   @id @default(cuid())
  branchId         String
  date             DateTime @db.Date
  kg12FullQty      Int      @default(0)
  kg12EmptyQty     Int      @default(0)
  kg12OnTransitQty Int      @default(0)
  kg12HmtQty       Int      @default(0)
  kg12KuotaWo      Int      @default(0)
  kg50FullQty      Int      @default(0)
  kg50EmptyQty     Int      @default(0)
  kg50OnTransitQty Int      @default(0)
  kg50HmtQty       Int      @default(0)
  kg50KuotaWo      Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([branchId, date])
}

model CustomerCylinderHolding {
  id          String   @id @default(cuid())
  branchId    String
  customerId  String
  date        DateTime @db.Date
  kg12HeldQty Int      @default(0)
  kg50HeldQty Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branch   Branch   @relation(fields: [branchId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])

  @@unique([customerId, date])
}

model GasbackLedger {
  id              String        @id @default(cuid())
  branchId        String
  customerId      String
  txType          GasbackTxType
  qty             Decimal       @db.Decimal(14, 4)
  amount          Decimal       @db.Decimal(14, 2)
  runningBalance  Decimal       @db.Decimal(14, 4)
  deliveryOrderId String?
  claimId         String?
  // NEW: link to cylinder return event that triggered this credit
  cylinderEventId String?
  txDate          DateTime
  notes           String?       @db.Text
  createdAt       DateTime      @default(now())

  branch        Branch         @relation(fields: [branchId], references: [id])
  customer      Customer       @relation(fields: [customerId], references: [id])
  deliveryOrder DeliveryOrder? @relation(fields: [deliveryOrderId], references: [id])
  claim         GasbackClaim?  @relation(fields: [claimId], references: [id])
  cylinderEvent CylinderEvent? @relation(fields: [cylinderEventId], references: [id])
}

model GasbackClaim {
  id          String    @id @default(cuid())
  branchId    String
  customerId  String
  claimNumber String    @unique @db.VarChar(50)
  qty         Decimal   @db.Decimal(14, 4)
  amount      Decimal   @db.Decimal(14, 2)
  isPaid      Boolean   @default(false)
  paidAt      DateTime?
  paymentRef  String?   @db.VarChar(100)
  notes       String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  branch         Branch          @relation(fields: [branchId], references: [id])
  customer       Customer        @relation(fields: [customerId], references: [id])
  gasbackLedgers GasbackLedger[]
}

model MonthlyRecon {
  id        String               @id @default(cuid())
  branchId  String
  month     Int
  year      Int
  status    ReconciliationStatus @default(OPEN)
  openedAt  DateTime             @default(now())
  lockedAt  DateTime?
  notes     String?              @db.Text
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([branchId, month, year])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String   @db.VarChar(120)
  role         UserRole
  branchId     String?
  isActive     Boolean  @default(true)
  employeeId   String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  branch   Branch?   @relation(fields: [branchId], references: [id])
  employee Employee?
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique @db.VarChar(100)
  value     String   @db.Text
  label     String?  @db.VarChar(200)
  notes     String?  @db.Text
  updatedBy String?  @db.VarChar(120)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── NEW: Individual Cylinder Tracking ───────────────────────────────────────
//
// DESIGN DECISIONS:
// 1. CylinderType = named size category (e.g. "12kg", "50kg") — NOT literal weight.
//    The tare weight, nominal full weight, and nominal gas content are configured
//    per CylinderType in SystemSetting (e.g. cylinder_type_12kg_tare_kg = 14.5).
//
// 2. CylinderUnit = one physical cylinder with a serial code.
//    weightEmpty  = tare weight (the cylinder shell, no gas)
//    weightFull   = weight when full of gas (set when received from supplier)
//    The difference = nominal gas content for that unit.
//
// 3. Gasback is calculated when the EMPTY cylinder is RETURNED and WEIGHED:
//    gasbackKg = weightFull - weightReturned
//    (gas remaining = what the customer still had left = their "credit" back to us)
//    This gets credited to the customer's gasback balance.
//
// 4. CylinderEvent = audit log of every custody/location change.
//    Each event records: who had it, where it went, any weight measurement.

model CylinderType {
  id              String       @id @default(cuid())
  // e.g. "KG12" or "KG50" — maps to the CylinderSize enum for compatibility
  size            CylinderSize @unique
  // Human-readable label, e.g. "Tabung 12 Kg" — configurable
  label           String       @db.VarChar(60)
  // Nominal tare weight (kg) — just the empty cylinder shell, no gas
  // Used as default when registering a new cylinder if individual tare not measured
  nominalTareKg   Decimal      @db.Decimal(8, 3)
  // Nominal full weight (kg) — cylinder + full gas
  nominalFullKg   Decimal      @db.Decimal(8, 3)
  // Derived: nominalFullKg - nominalTareKg = nominal gas content
  // Gasback threshold: if returnedWeight > (nominalFullKg - gasbackMinKg), no credit
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  cylinders CylinderUnit[]
}

model CylinderUnit {
  id           String            @id @default(cuid())
  branchId     String
  // Serial code printed on the cylinder — unique across ALL branches
  serialCode   String            @unique @db.VarChar(60)
  // Which size category this cylinder belongs to
  typeId       String
  // Individual measured tare weight (kg) — set on registration/inspection
  // If null, falls back to CylinderType.nominalTareKg
  tareWeightKg Decimal?          @db.Decimal(8, 3)
  // Current status
  status       CylinderStatus    @default(WAREHOUSE_FULL)
  // Current condition
  condition    CylinderCondition @default(GOOD)
  // Which customer currently holds this cylinder (null = in warehouse or transit)
  currentCustomerId String?
  // Free text location note for warehouse (e.g. "Rak A-3")
  locationNote String?           @db.VarChar(120)
  // Damage/notes
  notes        String?           @db.Text
  // Soft delete / written off
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  branch          Branch          @relation(fields: [branchId], references: [id])
  type            CylinderType    @relation(fields: [typeId], references: [id])
  events          CylinderEvent[]
}

model CylinderEvent {
  id              String            @id @default(cuid())
  branchId        String
  cylinderUnitId  String
  eventType       CylinderEventType
  eventAt         DateTime

  // ── Custody references (all optional — set depending on eventType) ──────────
  // Which DO this cylinder was dispatched on (DISPATCHED_TO_CUSTOMER)
  deliveryOrderId String?
  // Which EmptyReturn record this cylinder came back on (RETURNED_FROM_CUSTOMER)
  emptyReturnId   String?
  // Which write-off record (WRITTEN_OFF)
  writeoffId      String?
  // Customer involved (WITH_CUSTOMER custody)
  customerId      String?

  // ── Weight measurements (recorded at warehouse when cylinder is WEIGHED) ────
  // Weight when this cylinder LEFT warehouse (full) — set on DISPATCHED_TO_CUSTOMER
  weightDispatchedKg Decimal?  @db.Decimal(8, 3)
  // Weight when this cylinder RETURNED to warehouse — set on RETURNED_FROM_CUSTOMER
  weightReturnedKg   Decimal?  @db.Decimal(8, 3)
  // Computed: weightDispatchedKg - weightReturnedKg = gas consumed
  // Gasback = gas remaining = nominally (weightDispatchedKg - tareWeight) but:
  // gasbackKg = weightReturnedKg - tareWeight (what gas is left in the cylinder)
  // This is recorded here for audit trail
  gasbackKg          Decimal?  @db.Decimal(8, 3)

  // ── Condition at time of event ──────────────────────────────────────────────
  condition   CylinderCondition @default(GOOD)
  notes       String?           @db.Text
  recordedBy  String?           @db.VarChar(120) // user name who entered this
  createdAt   DateTime          @default(now())

  branch        Branch            @relation(fields: [branchId], references: [id])
  cylinderUnit  CylinderUnit      @relation(fields: [cylinderUnitId], references: [id])
  deliveryOrder DeliveryOrder?    @relation(fields: [deliveryOrderId], references: [id])
  emptyReturn   EmptyReturn?      @relation(fields: [emptyReturnId], references: [id])
  writeoff      CylinderWriteoff? @relation(fields: [writeoffId], references: [id])
  customer      Customer?         @relation(fields: [customerId], references: [id])
  // Gasback ledger entries that were created from this return weighing
  gasbackLedgers GasbackLedger[]
}

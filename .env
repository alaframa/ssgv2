# .env.example
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL="postgresql://app_user_ssgv2:StrongPassword123!@localhost:5432/appv2"



# NextAuth.js — generate a strong random secret:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="your-strong-random-secret-here"

# The public URL of the app (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# Node environment
NODE_ENV="development"


# UPDATE "User" 
# SET "passwordHash" = '$2a$12$LRZsGdSa5eFT69Ef/cCoDOx5AGksTLmWj6p.tK32cw3ffBwvDRaZu'
# WHERE email IN ('admin@ssg.id','manager.sby@ssg.id','manager.yog@ssg.id');



# GR — Good Receipt from supplier
# Default:  GR-{BRANCH}-{YYYY}{MM}-{NNNN}  → GR-SBY-202603-0042
FORMAT_GR="GR-{BRANCH}-{YYYY}{MM}-{NNNN}"

# CPO — Customer Purchase Order
# Default:  CPO-{BRANCH}-{YYYY}{MM}-{NNNN}  → CPO-SBY-202603-0001
FORMAT_CPO="CPO-{BRANCH}-{YYYY}{MM}-{NNNN}"

# DO — Delivery Order
# Default:  {MM}-{NNN}  → 03-001
FORMAT_DO="{MM}-{NNN}"

# SPO — Supplier Purchase Order
# Default:  PO-{YYYY}-{MM}-{NNNN}  → PO-2026-03-0018
FORMAT_SPO="PO-{YYYY}-{MM}-{NNNN}"

# CLAIM — Gasback Claim
# Default:  CLM-{BRANCH}-{NNNN}  → CLM-SBY-0001
FORMAT_CLAIM="CLM-{BRANCH}-{NNNN}"

# RETURN — Empty Cylinder Return
# Default:  RET-{BRANCH}-{YYYY}{MM}-{NNN}  → RET-SBY-202603-001
FORMAT_RETURN="RET-{BRANCH}-{YYYY}{MM}-{NNN}"

# WRITEOFF — Cylinder Write-off
# Default:  WO-{BRANCH}-{YYYY}{MM}-{NNN}  → WO-SBY-202603-001
FORMAT_WRITEOFF="WO-{BRANCH}-{YYYY}{MM}-{NNN}"

